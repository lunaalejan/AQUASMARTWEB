<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AquaSmart</title>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Roboto', sans-serif;
      margin: 0;
      padding: 0;
      background: #f0f8ff;
      color: #333;
    }

    header {
      background-color: #00aaff;
      color: white;
      padding: 20px 0;
      text-align: center;
    }

    header h1 {
      margin: 0;
      font-size: 2em;
    }

    nav {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 10px;
    }

    nav a {
      color: white;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      text-decoration: underline;
    }

    section {
      padding: 50px 20px;
      text-align: center;
    }

    section h2 {
      color: #00aaff;
      margin-bottom: 20px;
    }

    .cards {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
      margin-top: 30px;
    }

    .card {
      background: white;
      border-radius: 10px;
      padding: 20px;
      width: 250px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .card h3 {
      margin-top: 0;
    }

    footer {
      background-color: #00aaff;
      color: white;
      text-align: center;
      padding: 20px 0;
      margin-top: 50px;
    }

    /* Gráfico simulado */
    #chartContainer {
      margin: 0 auto;
      width: 80%;
      max-width: 600px;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header>
    <h1>AquaSmart</h1>
    <nav>
      <a href="#inicio">Inicio</a>
      <a href="#funciona">Cómo Funciona</a>
      <a href="#datos">Datos</a>
      <a href="#contacto">Contacto</a>
    </nav>
  </header>

  <!-- Sección de inicio -->
  <section id="inicio">
    <h2>Bienvenido a AquaSmart</h2>
    <p>Monitoreo inteligente del agua para tu hogar, jardín o empresa. Visualiza y controla el uso del agua de forma sencilla y eficiente.</p>
  </section>

  <!-- Sección cómo funciona -->
  <section id="funciona">
    <h2>Cómo Funciona</h2>
    <div class="cards">
      <div class="card">
        <h3>Sensor de Agua</h3>
        <p>Mide la cantidad y calidad del agua en tiempo real.</p>
      </div>
      <div class="card">
        <h3>App Móvil</h3>
        <p>Recibe notificaciones y controla el consumo desde tu celular.</p>
      </div>
      <div class="card">
        <h3>Panel Web</h3>
        <p>Visualiza gráficas y reportes históricos de manera intuitiva.</p>
      </div>
    </div>
  </section>

  <!-- Sección de datos (gráfico simulado) -->
  <section id="datos">
    <h2>Datos en Tiempo Real</h2>
    <canvas id="chart" width="400" height="200"></canvas>
  </section>

  <!-- Sección contacto -->
  <section id="contacto">
    <h2>Contacto</h2>
    <p>Para más información, escríbenos a <strong>contacto@aquasmart.com</strong></p>
  </section>

  <!-- Footer -->
  <footer>
    &copy; 2026 AquaSmart. Todos los derechos reservados.
  </footer>

  <!-- JS para gráfico simulado -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const ctx = document.getElementById('chart').getContext('2d');
    const chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['8:00', '10:00', '12:00', '14:00', '16:00', '18:00'],
        datasets: [{
          label: 'Nivel de Agua (litros)',
          data: [50, 55, 53, 60, 58, 62],
          borderColor: '#00aaff',
          backgroundColor: 'rgba(0,170,255,0.2)',
          fill: true,
          tension: 0.3
        }]
      }, 
      options: {
        responsive: true,
        scales: {
          y: { beginAtZero: true }
        }
      }
    });
  </script>

</body>
</html>